# Copy this file to .env for local-only configuration. Never commit real credentials.
DATABASE_PATH=./data/ai_job_radar.db
RADAR_CORS_ORIGIN=http://localhost:5173

# Optional future provider configuration. The MVP uses deterministic local templates by default.
LLM_PROVIDER=local
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional official-API placeholders. Leave empty unless you independently obtain credentials.
# No Cookie, token, account password, captcha, or anti-bot bypass is supported.
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
FREELANCER_API_TOKEN=
